exports[`end-to-end feed generation > generates atom.xml and rss.xml from fixtures 1`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<feed xmlns=\\"http://www.w3.org/2005/Atom\\">\\n  <title>Test Site</title>\\n  <subtitle>A test site for feed generation</subtitle>\\n  <link href=\\"https://example.com/\\" rel=\\"alternate\\"/>\\n  <link href=\\"https://example.com/atom.xml\\" rel=\\"self\\"/>\\n  <id>https://example.com/</id>\\n  <updated>2026-04-01T00:00:00Z</updated>\\n  <author>\\n    <name>Test Author</name>\\n  </author>\\n  <generator>pugneum-feed</generator>\\n  <entry>\\n    <title>Second Article - Test Site</title>\\n    <link href=\\"https://example.com/articles/second.html\\" rel=\\"alternate\\"/>\\n    <id>https://example.com/articles/second.html</id>\\n    <published>2026-04-01T00:00:00Z</published>\\n    <updated>2026-04-01T00:00:00Z</updated>\\n    <summary>Summary of the second article</summary>\\n    <content type=\\"html\\">&lt;h1&gt;Second Article&lt;/h1&gt;&lt;p&gt;Content of the second article.&lt;/p&gt;</content>\\n    <author>\\n      <name>Test Author</name>\\n    </author>\\n  </entry>\\n  <entry>\\n    <title>First Article - Test Site</title>\\n    <link href=\\"https://example.com/articles/first.html\\" rel=\\"alternate\\"/>\\n    <id>https://example.com/articles/first.html</id>\\n    <published>2026-03-15T00:00:00Z</published>\\n    <updated>2026-03-15T00:00:00Z</updated>\\n    <summary>Summary of the first article</summary>\\n    <content type=\\"html\\">&lt;h1&gt;First Article&lt;/h1&gt;&lt;p&gt;This is the full content of the first article.&lt;/p&gt;&lt;p&gt;It has multiple paragraphs.&lt;/p&gt;</content>\\n    <author>\\n      <name>First Author</name>\\n    </author>\\n  </entry>\\n</feed>\\n"
`;

exports[`end-to-end feed generation > generates atom.xml and rss.xml from fixtures 2`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<rss version=\\"2.0\\" xmlns:content=\\"http://purl.org/rss/1.0/modules/content/\\" xmlns:dc=\\"http://purl.org/dc/elements/1.1/\\" xmlns:atom=\\"http://www.w3.org/2005/Atom\\">\\n  <channel>\\n    <title>Test Site</title>\\n    <link>https://example.com/</link>\\n    <description>A test site for feed generation</description>\\n    <language>en</language>\\n    <lastBuildDate>Wed, 01 Apr 2026 00:00:00 GMT</lastBuildDate>\\n    <generator>pugneum-feed</generator>\\n    <atom:link href=\\"https://example.com/rss.xml\\" rel=\\"self\\" type=\\"application/rss+xml\\"/>\\n    <item>\\n      <title>Second Article - Test Site</title>\\n      <link>https://example.com/articles/second.html</link>\\n      <guid isPermaLink=\\"true\\">https://example.com/articles/second.html</guid>\\n      <pubDate>Wed, 01 Apr 2026 00:00:00 GMT</pubDate>\\n      <description>Summary of the second article</description>\\n      <content:encoded><![CDATA[<h1>Second Article</h1><p>Content of the second article.</p>]]></content:encoded>\\n      <dc:creator>Test Author</dc:creator>\\n    </item>\\n    <item>\\n      <title>First Article - Test Site</title>\\n      <link>https://example.com/articles/first.html</link>\\n      <guid isPermaLink=\\"true\\">https://example.com/articles/first.html</guid>\\n      <pubDate>Sun, 15 Mar 2026 00:00:00 GMT</pubDate>\\n      <description>Summary of the first article</description>\\n      <content:encoded><![CDATA[<h1>First Article</h1><p>This is the full content of the first article.</p><p>It has multiple paragraphs.</p>]]></content:encoded>\\n      <dc:creator>First Author</dc:creator>\\n    </item>\\n  </channel>\\n</rss>\\n"
`;
