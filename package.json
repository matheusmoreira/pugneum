{
  "name": "pugneum-repository",
  "private": true,
  "devDependencies": {
    "prettier": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "github:matheusmoreira/pugneum"
  },
  "scripts": {
    "prettier:check": "prettier --ignore-path .gitignore --list-different './**/*.js'",
    "format": "prettier --ignore-path .gitignore --write './**/*.js'",
    "test": "node --test 'packages/**/test/*.test.js'",
    "test:update-snapshots": "node --test --test-update-snapshots 'packages/**/test/*.test.js'"
  },
  "workspaces": [
    "packages/error",
    "packages/lexer",
    "packages/parser",
    "packages/loader",
    "packages/linker",
    "packages/filterer",
    "packages/renderer",
    "packages/walker",
    "packages/pugneum",
    "packages/filter/highlight.js",
    "packages/filter/prismjs",
    "packages/feed"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/matheusmoreira"
}
