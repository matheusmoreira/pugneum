exports[`generates valid Atom feed 1`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<feed xmlns=\\"http://www.w3.org/2005/Atom\\">\\n  <title>Test Site</title>\\n  <subtitle>A test site</subtitle>\\n  <link href=\\"https://example.com/\\" rel=\\"alternate\\"/>\\n  <link href=\\"https://example.com/atom.xml\\" rel=\\"self\\"/>\\n  <id>https://example.com/</id>\\n  <updated>2026-04-01T00:00:00Z</updated>\\n  <author>\\n    <name>Test Author</name>\\n  </author>\\n  <generator>pugneum-feed</generator>\\n  <entry>\\n    <title>Second Article</title>\\n    <link href=\\"https://example.com/articles/second.html\\" rel=\\"alternate\\"/>\\n    <id>https://example.com/articles/second.html</id>\\n    <published>2026-04-01T00:00:00Z</published>\\n    <updated>2026-04-01T00:00:00Z</updated>\\n    <summary>Summary of the second article</summary>\\n    <content type=\\"html\\">&lt;h1&gt;Second Article&lt;/h1&gt;&lt;p&gt;Content.&lt;/p&gt;</content>\\n    <author>\\n      <name>Test Author</name>\\n    </author>\\n  </entry>\\n  <entry>\\n    <title>First Article</title>\\n    <link href=\\"https://example.com/articles/first.html\\" rel=\\"alternate\\"/>\\n    <id>https://example.com/articles/first.html</id>\\n    <published>2026-03-15T00:00:00Z</published>\\n    <updated>2026-03-15T00:00:00Z</updated>\\n    <summary>Summary of the first article</summary>\\n    <content type=\\"html\\">&lt;h1&gt;First Article&lt;/h1&gt;&lt;p&gt;Content.&lt;/p&gt;</content>\\n    <author>\\n      <name>First Author</name>\\n    </author>\\n  </entry>\\n</feed>\\n"
`;

exports[`generates valid Atom feed with no entries 1`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<feed xmlns=\\"http://www.w3.org/2005/Atom\\">\\n  <title>Empty Site</title>\\n  <subtitle>No articles yet</subtitle>\\n  <link href=\\"https://example.com/\\" rel=\\"alternate\\"/>\\n  <link href=\\"https://example.com/atom.xml\\" rel=\\"self\\"/>\\n  <id>https://example.com/</id>\\n  <updated>2026-01-01T00:00:00Z</updated>\\n  <author>\\n    <name>Test Author</name>\\n  </author>\\n  <generator>pugneum-feed</generator>\\n</feed>\\n"
`;
