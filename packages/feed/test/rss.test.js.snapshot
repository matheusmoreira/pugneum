exports[`generates valid RSS feed 1`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<rss version=\\"2.0\\" xmlns:content=\\"http://purl.org/rss/1.0/modules/content/\\" xmlns:atom=\\"http://www.w3.org/2005/Atom\\">\\n  <channel>\\n    <title>Test Site</title>\\n    <link>https://example.com/</link>\\n    <description>A test site</description>\\n    <language>en</language>\\n    <lastBuildDate>Wed, 01 Apr 2026 00:00:00 GMT</lastBuildDate>\\n    <generator>pugneum-feed</generator>\\n    <atom:link href=\\"https://example.com/rss.xml\\" rel=\\"self\\" type=\\"application/rss+xml\\"/>\\n    <item>\\n      <title>Second Article</title>\\n      <link>https://example.com/articles/second.html</link>\\n      <guid isPermaLink=\\"true\\">https://example.com/articles/second.html</guid>\\n      <pubDate>Wed, 01 Apr 2026 00:00:00 GMT</pubDate>\\n      <description>Summary of the second article</description>\\n      <content:encoded><![CDATA[<h1>Second Article</h1><p>Content.</p>]]></content:encoded>\\n      <author>Test Author</author>\\n    </item>\\n    <item>\\n      <title>First Article</title>\\n      <link>https://example.com/articles/first.html</link>\\n      <guid isPermaLink=\\"true\\">https://example.com/articles/first.html</guid>\\n      <pubDate>Sun, 15 Mar 2026 00:00:00 GMT</pubDate>\\n      <description>Summary of the first article</description>\\n      <content:encoded><![CDATA[<h1>First Article</h1><p>Content.</p>]]></content:encoded>\\n      <author>First Author</author>\\n    </item>\\n  </channel>\\n</rss>\\n"
`;

exports[`generates valid RSS feed with no entries 1`] = `
"<?xml version=\\"1.0\\" encoding=\\"utf-8\\"?>\\n<rss version=\\"2.0\\" xmlns:content=\\"http://purl.org/rss/1.0/modules/content/\\" xmlns:atom=\\"http://www.w3.org/2005/Atom\\">\\n  <channel>\\n    <title>Empty Site</title>\\n    <link>https://example.com/</link>\\n    <description>No articles yet</description>\\n    <language>en</language>\\n    <lastBuildDate>Thu, 01 Jan 2026 00:00:00 GMT</lastBuildDate>\\n    <generator>pugneum-feed</generator>\\n    <atom:link href=\\"https://example.com/rss.xml\\" rel=\\"self\\" type=\\"application/rss+xml\\"/>\\n  </channel>\\n</rss>\\n"
`;
